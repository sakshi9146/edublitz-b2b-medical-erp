# Copy to .env and fill in values. Required: JWT_SECRET + all three Atlas URIs.
# Atlas: create users_db, products_db, orders_db (or path suffixes you prefer) and allow your host IP / 0.0.0.0/0 for dev.

MONGODB_URI_USERS=mongodb+srv://USER:PASS@cluster.example.mongodb.net/users_db?retryWrites=true&w=majority
MONGODB_URI_PRODUCTS=mongodb+srv://USER:PASS@cluster.example.mongodb.net/products_db?retryWrites=true&w=majority
MONGODB_URI_ORDERS=mongodb+srv://USER:PASS@cluster.example.mongodb.net/orders_db?retryWrites=true&w=majority

# Same Base64-encoded secret on every JVM (openssl rand -base64 32)
JWT_SECRET=

# SPA is on S3/CloudFront — set your site origin for production CORS. Use * only for local demos.
CORS_ALLOWED_ORIGINS=*
