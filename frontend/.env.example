# Local dev: leave unset to use Vite proxy (/api/user → localhost:8081).
# Optional proxy host (default 127.0.0.1):
# VITE_PROXY_API_HOST=13.239.35.112

# Production build (`npm run build`): set full API URLs if the web server has no /api reverse proxy.
# See `frontend/.env.production` for an example targeting your deployment host.
